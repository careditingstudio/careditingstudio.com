# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Legacy CMS JSON (removed from app — CMS is Postgres only)
/data/cms.json

# local CMS database (SQLite; migrate to Postgres in production if needed)
/data/cms.sqlite
/data/cms.sqlite-wal
/data/cms.sqlite-shm

# CMS uploads (keep folder via .gitkeep)
/public/cms/uploads/*
!/public/cms/uploads/.gitkeep
