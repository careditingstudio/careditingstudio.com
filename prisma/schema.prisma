generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Vercel ↔ Supabase integration names only (see src/config/deployment-env.ts).
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum MailboxKind {
  CONTACT
  FREE_TRIAL
}

model SiteSettings {
  id              Int    @id @default(1)
  businessName    String @map("business_name")
  domainLabel     String @map("domain_label")
  email           String
  whatsappDial    String @map("whatsapp_dial")
  whatsappDisplay String @map("whatsapp_display")
  socialLinksJson String @default("[]") @map("social_links_json")
  officeLocationsJson String @default("[]") @map("office_locations_json")
  siteTagsText    String @default("") @map("site_tags_text")
  siteTagsSeparator String @default("newline") @map("site_tags_separator")
  floatingCar     String @default("") @map("floating_car")
  homeReviewsEyebrow  String @default("") @map("home_reviews_eyebrow")
  homeReviewsTitle    String @default("") @map("home_reviews_title")
  homeReviewsSubtitle String @default("") @map("home_reviews_subtitle")
  homeServiceFeaturesJson String @default("{}") @map("home_service_features_json")
  homeWhyChooseUsJson     String @default("{}") @map("home_why_choose_us_json")
  updatedAt       String @default("") @map("updated_at")

  @@map("site_settings")
}

model ClientReview {
  id         Int    @id @default(autoincrement())
  sortOrder  Int    @map("sort_order")
  clientName String @map("client_name")
  role       String @default("")
  rating     Int    @default(5)
  message    String
  avatarUrl  String @default("") @map("avatar_url")

  @@map("client_reviews")
}

model MailboxMessage {
  id        Int         @id @default(autoincrement())
  kind      MailboxKind
  createdAt DateTime    @default(now()) @map("created_at")
  readAt    DateTime?   @map("read_at")

  fullName        String  @map("full_name")
  email           String?
  whatsapp        String?
  country         String?
  message         String
  requirements    String?

  ip        String? @map("ip")
  userAgent String? @map("user_agent")

  @@index([kind, createdAt(sort: Desc)])
  @@index([readAt])
  @@map("mailbox_messages")
}

model HeroBanner {
  id        Int    @id @default(autoincrement())
  sortOrder Int    @map("sort_order")
  url       String

  @@map("hero_banners")
}

model BeforeAfterPost {
  id                 Int     @id @default(autoincrement())
  sortOrder          Int     @map("sort_order")
  beforeUrl          String  @map("before_url")
  afterUrl           String  @map("after_url")
  title              String
  intro              String
  priceNote          String  @map("price_note")
  listTitle          String  @map("list_title")
  includesJson       String  @map("includes_json")
  beforeAlt          String  @map("before_alt")
  afterAlt           String  @map("after_alt")
  imageFirst         Boolean @default(false) @map("image_first")
  showDualCtas       Boolean @default(true) @map("show_dual_ctas")
  primaryCtaLabel    String  @default("") @map("primary_cta_label")
  primaryCtaHref     String  @default("") @map("primary_cta_href")
  secondaryCtaLabel String @default("") @map("secondary_cta_label")
  secondaryCtaHref   String  @default("") @map("secondary_cta_href")
  soloCtaLabel       String  @default("") @map("solo_cta_label")
  soloCtaHref        String  @default("") @map("solo_cta_href")

  @@map("before_after_posts")
}

model Service {
  id        Int             @id @default(autoincrement())
  sortOrder Int             @map("sort_order")
  name      String
  portfolio PortfolioItem[]

  @@map("services")
}

model PortfolioItem {
  id                 Int     @id @default(autoincrement())
  sortOrder          Int     @map("sort_order")
  label              String
  serviceId          Int?    @map("service_id")
  service            Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  beforeUrl          String  @map("before_url")
  afterUrl           String  @map("after_url")
  beforeAlt          String  @map("before_alt")
  afterAlt           String  @map("after_alt")
  /** 1–5 = slot on homepage strip; null = not featured */
  homeFeaturedOrder  Int?    @map("home_featured_order")

  @@map("portfolio_items")
}
